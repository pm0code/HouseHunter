# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL 17 + PostGIS 3.5 (Docker, port 5433)
DATABASE_URL=postgresql://househunter:househunter_dev@localhost:5433/househunter
POSTGRES_DB=househunter
POSTGRES_USER=househunter
POSTGRES_PASSWORD=househunter_dev

# ── Cache ────────────────────────────────────────────────────────────────────
# Valkey 8 (FOSS Redis fork, port 6380)
VALKEY_URL=redis://localhost:6380

# ── Email ────────────────────────────────────────────────────────────────────
# Dev: Mailpit SMTP at port 1025 — view at http://localhost:8025
# Prod: replace with your self-hosted SMTP relay
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
SMTP_FROM="HouseHunter <noreply@househunter.local>"
ADMIN_EMAIL=admin@househunter.local

# ── Self-hosted services ─────────────────────────────────────────────────────
# OSRM pedestrian routing engine (Docker, profile: enrichment)
OSRM_URL=http://localhost:5000
# Nominatim geocoding engine (Docker, profile: enrichment)
NOMINATIM_URL=http://localhost:7070
# Nominatim Docker password
NOMINATIM_PASSWORD=nominatim_dev
# Nominatim OSM PBF source for first-time import
# NOMINATIM_PBF_URL=https://download.geofabrik.de/north-america/us/new-york-city-latest.osm.pbf

# ── App ──────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3100
# Secret for signing tokens (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
TOKEN_SECRET=change-me-in-production

# ── NYC Open Data ────────────────────────────────────────────────────────────
# Register free at https://data.cityofnewyork.us/profile/app_tokens
# Required to avoid IP rate limiting on NYPD complaint data import
NYCOPENDATA_APP_TOKEN=
